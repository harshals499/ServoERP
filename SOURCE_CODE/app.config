<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <add name="HVACPro_Connection"
         connectionString="Server=.\SQLEXPRESS;Database=HVAC_PRO;Integrated Security=True;Pooling=True;Min Pool Size=0;Max Pool Size=100;Connect Timeout=15;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="CompanyName" value="ServoERP" />
    <add key="CompanyAddress" value="" />
    <add key="CompanyPhone" value="" />
    <add key="CompanyGSTIN" value="" />
    <add key="GST_Rate" value="0.18" />
    <add key="SLA_ResponseTimeHours" value="2" />
    <add key="SLA_UptimePercent" value="99.5" />
    <add key="SLA_RepairTimeHours" value="4" />
    <add key="ContractRenewalDaysBefore" value="90" />
    <add key="InvoiceDueDays" value="30" />
    <add key="GoogleMapsApiKey" value="" />
  </appSettings>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>
