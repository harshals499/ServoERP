<?xml version="1.0" encoding="utf-8"?>
<HVACProConfig>
  <Database>
    <Server>.\SQLEXPRESS</Server>
    <DatabaseName>HVAC_PRO</DatabaseName>
    <UseWindowsAuth>true</UseWindowsAuth>
    <Username>
    </Username>
    <Password>
    </Password>
    <MaxPoolSize>100</MaxPoolSize>
    <ServerRole>AlwaysOnOfficeServer</ServerRole>
  </Database>
  <Fallback>
    <Mode>LocalSQLiteDiagnostics</Mode>
    <SqlitePath>C:\HVAC_PRO_MSE\DATABASE\ServoERP_Fallback.sqlite</SqlitePath>
    <AllowBusinessWrites>false</AllowBusinessWrites>
  </Fallback>
  <Tenant>
    <TenantCode>default</TenantCode>
    <SeedDemoData>false</SeedDemoData>
  </Tenant>
  <Setup>
    <ServerFirstRunRequired>false</ServerFirstRunRequired>
    <ServerFirstRunComplete>false</ServerFirstRunComplete>
  </Setup>
  <App>
    <Version>1.1.15</Version>
    <VersionCheckUrl>https://github.com/harshals499/ServoERP</VersionCheckUrl>
    <GitHubRepositoryUrl>https://github.com/harshals499/ServoERP</GitHubRepositoryUrl>
    <VersionCheckEnabled>true</VersionCheckEnabled>
    <VersionCheckIntervalHours>24</VersionCheckIntervalHours>
    <SilentAutoUpdateEnabled>false</SilentAutoUpdateEnabled>
    <SilentAutoUpdateApplyImmediately>false</SilentAutoUpdateApplyImmediately>
    <SilentAutoUpdateApplyOnExit>false</SilentAutoUpdateApplyOnExit>
    <LastUpdateCheckStatus>Updates have not been checked in this session.</LastUpdateCheckStatus>
    <UpdateDismissedUntil>
    </UpdateDismissedUntil>
  </App>
  <Mail>
    <OutlookTenant>common</OutlookTenant>
    <OutlookClientId>
    </OutlookClientId>
    <GmailClientId>
    </GmailClientId>
    <GmailClientSecret>
    </GmailClientSecret>
  </Mail>
  <Licensing>
    <ActivationUrl>https://servoerp.in/api/license/activate</ActivationUrl>
    <ValidationUrl>https://servoerp.in/api/license/validate</ValidationUrl>
  </Licensing>
  <TallyPrime>
    <Enabled>false</Enabled>
    <EndpointUrl>http://localhost:9000</EndpointUrl>
    <ExportFolder>
    </ExportFolder>
    <SalesLedgerName>Sales</SalesLedgerName>
    <PurchaseLedgerName>Purchase</PurchaseLedgerName>
    <GstLedgerName>GST Output</GstLedgerName>
  </TallyPrime>
  <WhatsAppCloud>
    <GraphVersion>v20.0</GraphVersion>
    <PhoneNumberId>
    </PhoneNumberId>
    <AccessToken>
    </AccessToken>
  </WhatsAppCloud>
  <CalendarDispatch>
    <ExportFolder>
    </ExportFolder>
  </CalendarDispatch>
  <CloudBackup>
    <Enabled>false</Enabled>
    <TargetType>LocalFolder</TargetType>
    <TargetPath>
    </TargetPath>
    <UploadUrl>
    </UploadUrl>
    <BearerToken>
    </BearerToken>
  </CloudBackup>
  <GstEinvoice>
    <Enabled>false</Enabled>
    <EndpointUrl>
    </EndpointUrl>
    <ClientId>
    </ClientId>
    <ClientSecret>
    </ClientSecret>
    <Gstin>
    </Gstin>
    <BearerToken>
    </BearerToken>
    <DefaultHsnSac>998719</DefaultHsnSac>
  </GstEinvoice>
  <FieldServiceForms>
    <RootFolder>C:\HVAC_PRO_MSE\research_downloads\field_service_forms</RootFolder>
    <ZipPath>C:\HVAC_PRO_MSE\research_downloads\ServoERP_Field_Service_Form_Templates.zip</ZipPath>
  </FieldServiceForms>
  <AI>
    <ModelName>qwen2.5:1.5b</ModelName>
    <Provider>Ollama</Provider>
    <TimeoutSeconds>60</TimeoutSeconds>
    <Temperature>0.2</Temperature>
    <EndpointUrl>http://localhost:11434</EndpointUrl>
    <MaxTokens>700</MaxTokens>
    <Enabled>true</Enabled>
  </AI>
</HVACProConfig>