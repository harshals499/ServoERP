PORT=3000
DEMO_REQUEST_TO_EMAIL=support@servoerp.in
DEMO_REQUEST_FROM_EMAIL=no-reply@servoerp.in
DEMO_REQUEST_DATA_DIR=./data

# SMTP provider settings: Resend SMTP, SendGrid SMTP, or any production SMTP relay.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey-or-smtp-user
SMTP_PASS=replace-with-secret

# Local development only. Do not enable this in production.
DEMO_REQUEST_ALLOW_STUB_EMAIL=false
